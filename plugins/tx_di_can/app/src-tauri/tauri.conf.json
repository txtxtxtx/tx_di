{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CAN 诊断上位机",
  "version": "0.1.0",
  "identifier": "com.txdi.canhost",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CAN 诊断上位机",
        "width": 1366,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
